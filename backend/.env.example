# Copy this file to `.env` and fill in the real values.
# Get MINIMAX_API_KEY from the MiniMax dashboard.
# SECURITY: never commit the real key. `.env` is gitignored; this file is NOT.
#
# NOTE: a key previously committed to this file must be considered leaked.
# Rotate it in the MiniMax dashboard and update the deployed Render env var
# before continuing development.

MINIMAX_API_KEY=your-key-here

# Optional overrides (defaults shown below match the code in server.js):
# PORT=3001
# ALLOWED_ORIGINS=http://localhost:5173,https://tangsanyi-blog.onrender.com
